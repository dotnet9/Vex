<u:UrsaWindow
    x:Class="Vex.Modules.Help.Views.MarkdownDocumentWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:md="https://codewf.com"
    xmlns:u="https://irihi.tech/ursa"
    Width="460"
    Height="560"
    MinWidth="560"
    MinHeight="420"
    CanMaximize="False"
    CanMinimize="False"
    Icon="/Assets/logo.ico"
    IsFullScreenButtonVisible="False"
    IsMinimizeButtonVisible="False"
    IsRestoreButtonVisible="False"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner">
    <u:UrsaWindow.LeftContent>
        <TextBlock
            x:Name="TitleText"
            FontSize="13"
            FontWeight="SemiBold"
            Margin="12 0 0 0"
            VerticalAlignment="Center" />
    </u:UrsaWindow.LeftContent>

    <Border
        Background="{DynamicResource VexPreviewBackgroundBrush}"
        Padding="34 28">
        <ScrollViewer
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <md:MarkdownViewer x:Name="DocumentMarkdownViewer" />
        </ScrollViewer>
    </Border>
</u:UrsaWindow>
