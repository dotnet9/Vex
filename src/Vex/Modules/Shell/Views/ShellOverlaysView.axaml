<UserControl
    x:Class="Vex.Modules.Shell.Views.ShellOverlaysView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Vex.Modules.Shell.ViewModels"
    x:DataType="vm:MainWindowViewModel">
    <Grid>
        <Border
            Width="270"
            Margin="0 14 18 0"
            Padding="16"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Background="#FFFFFFFF"
            BorderBrush="#D0D5DD"
            BorderThickness="1"
            CornerRadius="8"
            IsVisible="{Binding Dialogs.IsStatisticsPanelVisible}">
            <Grid RowDefinitions="Auto,Auto" RowSpacing="12">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock
                        FontSize="15"
                        FontWeight="SemiBold"
                        Text="Statistics" />
                    <Button
                        Grid.Column="1"
                        Command="{Binding Dialogs.CloseStatisticsPanel}"
                        Content="X"
                        MinWidth="34"
                        Padding="0" />
                </Grid>
                <Grid
                    Grid.Row="1"
                    ColumnDefinitions="*,Auto"
                    RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                    RowSpacing="8">
                    <TextBlock Classes="muted" Text="Words" />
                    <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="{Binding Statistics.Words}" />
                    <TextBlock Grid.Row="1" Classes="muted" Text="Characters" />
                    <TextBlock Grid.Row="1" Grid.Column="1" FontWeight="SemiBold" Text="{Binding Statistics.Characters}" />
                    <TextBlock Grid.Row="2" Classes="muted" Text="Lines" />
                    <TextBlock Grid.Row="2" Grid.Column="1" FontWeight="SemiBold" Text="{Binding Statistics.Lines}" />
                    <TextBlock Grid.Row="3" Classes="muted" Text="Encoding" />
                    <TextBlock Grid.Row="3" Grid.Column="1" FontWeight="SemiBold" Text="{Binding CurrentEncodingText}" />
                    <TextBlock Grid.Row="4" Classes="muted" Text="State" />
                    <TextBlock Grid.Row="4" Grid.Column="1" FontWeight="SemiBold" Text="{Binding DocumentStateText}" />
                </Grid>
            </Grid>
        </Border>

        <Border
            Width="360"
            Padding="20"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="#FFFFFFFF"
            BorderBrush="#D0D5DD"
            BorderThickness="1"
            CornerRadius="8"
            IsVisible="{Binding Dialogs.IsAboutPanelVisible}">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="14">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                    <Image Width="32" Height="32" Source="/Assets/logo.png" />
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Vex" />
                        <TextBlock Classes="muted" Text="极简之力，妙笔成章" />
                    </StackPanel>
                    <Button
                        Grid.Column="2"
                        Command="{Binding Dialogs.CloseAboutPanel}"
                        Content="X"
                        MinWidth="34"
                        Padding="0" />
                </Grid>
                <Grid
                    Grid.Row="1"
                    ColumnDefinitions="Auto,*"
                    RowDefinitions="Auto,Auto,Auto,Auto"
                    RowSpacing="8"
                    ColumnSpacing="14">
                    <TextBlock Classes="muted" Text="中文名" />
                    <TextBlock Grid.Column="1" Text="维刻" />
                    <TextBlock Grid.Row="1" Classes="muted" Text="作者" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="沙漠尽头的狼" />
                    <TextBlock Grid.Row="2" Classes="muted" Text="网站" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="https://codewf.com" />
                    <TextBlock Grid.Row="3" Classes="muted" Text="品牌" />
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="CodeWF（码坊）" />
                </Grid>
                <Separator Grid.Row="2" />
                <TextBlock
                    Grid.Row="3"
                    Classes="muted"
                    Text="Markdown editor powered by Avalonia, Prism, and CodeWF libraries."
                    TextWrapping="Wrap" />
            </Grid>
        </Border>

        <Border
            Width="420"
            Padding="20"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="#FFFFFFFF"
            BorderBrush="#D0D5DD"
            BorderThickness="1"
            CornerRadius="8"
            IsVisible="{Binding Dialogs.IsPropertiesPanelVisible}">
            <Grid RowDefinitions="Auto,Auto" RowSpacing="14">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock
                        FontSize="17"
                        FontWeight="SemiBold"
                        Text="Properties" />
                    <Button
                        Grid.Column="1"
                        Command="{Binding Dialogs.ClosePropertiesPanel}"
                        Content="X"
                        MinWidth="34"
                        Padding="0" />
                </Grid>
                <Grid
                    Grid.Row="1"
                    ColumnDefinitions="Auto,*"
                    RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                    RowSpacing="9"
                    ColumnSpacing="16">
                    <TextBlock Classes="muted" Text="Name" />
                    <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="{Binding PropertyNameText}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Row="1" Classes="muted" Text="State" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DocumentStateText}" />
                    <TextBlock Grid.Row="2" Classes="muted" Text="Encoding" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CurrentEncodingText}" />
                    <TextBlock Grid.Row="3" Classes="muted" Text="Size" />
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding PropertySizeText}" />
                    <TextBlock Grid.Row="4" Classes="muted" Text="Path" />
                    <TextBlock
                        Grid.Row="4"
                        Grid.Column="1"
                        Text="{Binding PropertyLocationText}"
                        TextTrimming="CharacterEllipsis" />
                </Grid>
            </Grid>
        </Border>

        <Border Background="#66000000" IsVisible="{Binding Dialogs.IsDeleteConfirmVisible}">
            <Border
                Width="420"
                Padding="22"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#FFFFFFFF"
                BorderBrush="#D0D5DD"
                BorderThickness="1"
                CornerRadius="8">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="14">
                    <TextBlock
                        FontSize="17"
                        FontWeight="SemiBold"
                        Text="{Binding Dialogs.DeleteConfirmText}"
                        TextWrapping="Wrap" />
                    <TextBlock
                        Grid.Row="1"
                        Classes="muted"
                        Text="This file will be permanently deleted from disk."
                        TextWrapping="Wrap" />
                    <Border
                        Grid.Row="2"
                        Padding="10 8"
                        Background="#FFF8FAFC"
                        BorderBrush="#E4E7EC"
                        BorderThickness="1"
                        CornerRadius="6">
                        <TextBlock
                            Classes="muted"
                            FontFamily="Consolas, Cascadia Mono, Microsoft YaHei UI"
                            FontSize="12"
                            Text="{Binding Dialogs.DeleteConfirmPath}"
                            TextTrimming="CharacterEllipsis" />
                    </Border>
                    <StackPanel
                        Grid.Row="3"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal"
                        Spacing="8">
                        <Button
                            Command="{Binding Dialogs.CancelDelete}"
                            Content="Cancel"
                            MinWidth="86" />
                        <Button
                            Command="{Binding ConfirmDeleteAsync}"
                            Content="Delete"
                            MinWidth="86" />
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <Border Background="#66000000" IsVisible="{Binding Dialogs.IsUnsavedConfirmVisible}">
            <Border
                Width="440"
                Padding="22"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#FFFFFFFF"
                BorderBrush="#D0D5DD"
                BorderThickness="1"
                CornerRadius="8">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="14">
                    <TextBlock
                        FontSize="17"
                        FontWeight="SemiBold"
                        Text="{Binding Dialogs.UnsavedConfirmTitle}"
                        TextWrapping="Wrap" />
                    <TextBlock
                        Grid.Row="1"
                        Classes="muted"
                        Text="{Binding Dialogs.UnsavedConfirmMessage}"
                        TextWrapping="Wrap" />
                    <Border
                        Grid.Row="2"
                        Padding="10 8"
                        Background="#FFF8FAFC"
                        BorderBrush="#E4E7EC"
                        BorderThickness="1"
                        CornerRadius="6">
                        <TextBlock
                            Classes="muted"
                            FontFamily="Consolas, Cascadia Mono, Microsoft YaHei UI"
                            FontSize="12"
                            Text="{Binding Dialogs.UnsavedConfirmPath}"
                            TextTrimming="CharacterEllipsis" />
                    </Border>
                    <StackPanel
                        Grid.Row="3"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal"
                        Spacing="8">
                        <Button
                            Command="{Binding Dialogs.CancelPendingAction}"
                            Content="Cancel"
                            MinWidth="84" />
                        <Button
                            Command="{Binding DiscardPendingActionAsync}"
                            Content="Don't Save"
                            MinWidth="104" />
                        <Button
                            Command="{Binding SavePendingActionAsync}"
                            Content="Save"
                            MinWidth="84" />
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
