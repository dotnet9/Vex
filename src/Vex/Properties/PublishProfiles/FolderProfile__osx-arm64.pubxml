<?xml version="1.0" encoding="utf-8"?>
<Project>
  <PropertyGroup>
    <PublishProtocol>FileSystem</PublishProtocol>
    <PublishProvider>FileSystem</PublishProvider>
    <WebPublishMethod>FileSystem</WebPublishMethod>
    <LaunchSiteAfterPublish>false</LaunchSiteAfterPublish>
    <DeleteExistingFiles>true</DeleteExistingFiles>
    <LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
    <Configuration>Release</Configuration>
    <LastUsedPlatform>Any CPU</LastUsedPlatform>
    <Platform>Any CPU</Platform>
    <LastUsedTargetFramework>net10.0</LastUsedTargetFramework>
    <TargetFramework>net10.0</TargetFramework>
    <LastUsedRuntimeIdentifier>osx-arm64</LastUsedRuntimeIdentifier>
    <RuntimeIdentifier>osx-arm64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <IncludeAllContentForSelfExtract>true</IncludeAllContentForSelfExtract>
    <PublishUrl>bin\Release\net10.0\osx-arm64\publish\</PublishUrl>
    <PublishDir>bin\Release\net10.0\osx-arm64\publish\</PublishDir>
    <_TargetId>Folder</_TargetId>
  </PropertyGroup>
</Project>
