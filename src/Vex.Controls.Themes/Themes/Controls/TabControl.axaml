<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:semi="https://irihi.tech/semi">
    <Styles.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="TabControlSeparatorBorderBrush" Color="#E4E7EC" />
                    <SolidColorBrush x:Key="TabItemLinePipeSelectedBackground" Color="#1677FF" />
                    <SolidColorBrush x:Key="TabItemLinePipePointeroverBorderBrush" Color="#D8DEE8" />
                    <SolidColorBrush x:Key="TabItemLinePipePressedBorderBrush" Color="#1677FF" />
                    <SolidColorBrush x:Key="TabItemLineHeaderForeground" Color="#667085" />
                    <SolidColorBrush x:Key="TabItemLineHeaderPointeroverForeground" Color="#101828" />
                    <SolidColorBrush x:Key="TabItemLineHeaderSelectedForeground" Color="#101828" />
                    <SolidColorBrush x:Key="TabItemLineHeaderSelectedBackground" Color="#F8FAFC" />
                    <SolidColorBrush x:Key="TabItemLineHeaderPointeroverBackground" Color="#F2F4F7" />
                    <SolidColorBrush x:Key="TabItemLineHeaderPressedBackground" Color="#E8F1FF" />
                    <SolidColorBrush x:Key="TabItemIconSelectedForeground" Color="#1677FF" />
                    <SolidColorBrush x:Key="TabItemHeaderDisabledForeground" Color="#98A2B3" />
                </ResourceDictionary>

                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="TabControlSeparatorBorderBrush" Color="#2B3443" />
                    <SolidColorBrush x:Key="TabItemLinePipeSelectedBackground" Color="#60A5FA" />
                    <SolidColorBrush x:Key="TabItemLinePipePointeroverBorderBrush" Color="#334155" />
                    <SolidColorBrush x:Key="TabItemLinePipePressedBorderBrush" Color="#60A5FA" />
                    <SolidColorBrush x:Key="TabItemLineHeaderForeground" Color="#AAB4C3" />
                    <SolidColorBrush x:Key="TabItemLineHeaderPointeroverForeground" Color="#F8FAFC" />
                    <SolidColorBrush x:Key="TabItemLineHeaderSelectedForeground" Color="#F3F4F6" />
                    <SolidColorBrush x:Key="TabItemLineHeaderSelectedBackground" Color="#1B2533" />
                    <SolidColorBrush x:Key="TabItemLineHeaderPointeroverBackground" Color="#263244" />
                    <SolidColorBrush x:Key="TabItemLineHeaderPressedBackground" Color="#1D3A5F" />
                    <SolidColorBrush x:Key="TabItemIconSelectedForeground" Color="#60A5FA" />
                    <SolidColorBrush x:Key="TabItemHeaderDisabledForeground" Color="#7D8999" />
                </ResourceDictionary>

                <ResourceDictionary x:Key="{x:Static semi:SemiTheme.Aquatic}">
                    <SolidColorBrush x:Key="TabControlSeparatorBorderBrush" Color="#CDE9EF" />
                    <SolidColorBrush x:Key="TabItemLinePipeSelectedBackground" Color="#0EA5B7" />
                    <SolidColorBrush x:Key="TabItemLinePipePointeroverBorderBrush" Color="#CDE9EF" />
                    <SolidColorBrush x:Key="TabItemLinePipePressedBorderBrush" Color="#0EA5B7" />
                    <SolidColorBrush x:Key="TabItemLineHeaderForeground" Color="#5C7880" />
                    <SolidColorBrush x:Key="TabItemLineHeaderPointeroverForeground" Color="#16323A" />
                    <SolidColorBrush x:Key="TabItemLineHeaderSelectedForeground" Color="#16323A" />
                    <SolidColorBrush x:Key="TabItemLineHeaderSelectedBackground" Color="#EFF8FA" />
                    <SolidColorBrush x:Key="TabItemLineHeaderPointeroverBackground" Color="#DFF7FA" />
                    <SolidColorBrush x:Key="TabItemLineHeaderPressedBackground" Color="#CDEFF5" />
                    <SolidColorBrush x:Key="TabItemIconSelectedForeground" Color="#0EA5B7" />
                    <SolidColorBrush x:Key="TabItemHeaderDisabledForeground" Color="#7A99A1" />
                </ResourceDictionary>

                <ResourceDictionary x:Key="{x:Static semi:SemiTheme.Desert}">
                    <SolidColorBrush x:Key="TabControlSeparatorBorderBrush" Color="#E8D9C2" />
                    <SolidColorBrush x:Key="TabItemLinePipeSelectedBackground" Color="#C77B2A" />
                    <SolidColorBrush x:Key="TabItemLinePipePointeroverBorderBrush" Color="#E8D9C2" />
                    <SolidColorBrush x:Key="TabItemLinePipePressedBorderBrush" Color="#C77B2A" />
                    <SolidColorBrush x:Key="TabItemLineHeaderForeground" Color="#7A6752" />
                    <SolidColorBrush x:Key="TabItemLineHeaderPointeroverForeground" Color="#32261B" />
                    <SolidColorBrush x:Key="TabItemLineHeaderSelectedForeground" Color="#32261B" />
                    <SolidColorBrush x:Key="TabItemLineHeaderSelectedBackground" Color="#FFF5E8" />
                    <SolidColorBrush x:Key="TabItemLineHeaderPointeroverBackground" Color="#FFF0D9" />
                    <SolidColorBrush x:Key="TabItemLineHeaderPressedBackground" Color="#F4DEC2" />
                    <SolidColorBrush x:Key="TabItemIconSelectedForeground" Color="#C77B2A" />
                    <SolidColorBrush x:Key="TabItemHeaderDisabledForeground" Color="#9A856D" />
                </ResourceDictionary>

                <ResourceDictionary x:Key="{x:Static semi:SemiTheme.Dusk}">
                    <SolidColorBrush x:Key="TabControlSeparatorBorderBrush" Color="#DDD7EA" />
                    <SolidColorBrush x:Key="TabItemLinePipeSelectedBackground" Color="#8A63D2" />
                    <SolidColorBrush x:Key="TabItemLinePipePointeroverBorderBrush" Color="#DDD7EA" />
                    <SolidColorBrush x:Key="TabItemLinePipePressedBorderBrush" Color="#8A63D2" />
                    <SolidColorBrush x:Key="TabItemLineHeaderForeground" Color="#72637F" />
                    <SolidColorBrush x:Key="TabItemLineHeaderPointeroverForeground" Color="#2C2237" />
                    <SolidColorBrush x:Key="TabItemLineHeaderSelectedForeground" Color="#2C2237" />
                    <SolidColorBrush x:Key="TabItemLineHeaderSelectedBackground" Color="#F3F1FA" />
                    <SolidColorBrush x:Key="TabItemLineHeaderPointeroverBackground" Color="#F0E9FF" />
                    <SolidColorBrush x:Key="TabItemLineHeaderPressedBackground" Color="#E3DAF8" />
                    <SolidColorBrush x:Key="TabItemIconSelectedForeground" Color="#8A63D2" />
                    <SolidColorBrush x:Key="TabItemHeaderDisabledForeground" Color="#8A7A98" />
                </ResourceDictionary>

                <ResourceDictionary x:Key="{x:Static semi:SemiTheme.NightSky}">
                    <SolidColorBrush x:Key="TabControlSeparatorBorderBrush" Color="#2D3A52" />
                    <SolidColorBrush x:Key="TabItemLinePipeSelectedBackground" Color="#7AA2FF" />
                    <SolidColorBrush x:Key="TabItemLinePipePointeroverBorderBrush" Color="#2D3A52" />
                    <SolidColorBrush x:Key="TabItemLinePipePressedBorderBrush" Color="#7AA2FF" />
                    <SolidColorBrush x:Key="TabItemLineHeaderForeground" Color="#AAB6C8" />
                    <SolidColorBrush x:Key="TabItemLineHeaderPointeroverForeground" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="TabItemLineHeaderSelectedForeground" Color="#EBF2FF" />
                    <SolidColorBrush x:Key="TabItemLineHeaderSelectedBackground" Color="#1E2A3F" />
                    <SolidColorBrush x:Key="TabItemLineHeaderPointeroverBackground" Color="#1E2A3F" />
                    <SolidColorBrush x:Key="TabItemLineHeaderPressedBackground" Color="#1E335A" />
                    <SolidColorBrush x:Key="TabItemIconSelectedForeground" Color="#7AA2FF" />
                    <SolidColorBrush x:Key="TabItemHeaderDisabledForeground" Color="#7F8CA3" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Styles.Resources>

    <Style Selector="TabControl.sidebar-tabs TabItem">
        <Setter Property="MinHeight" Value="48" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="TabControl.sidebar-tabs TabItem:selected">
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
</Styles>
