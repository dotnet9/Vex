<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:semi="https://irihi.tech/semi">
    <Styles.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="ScrollBarButtonDefaultForeground" Color="#98A2B3" />
                    <SolidColorBrush x:Key="ScrollBarButtonPointeroverForeground" Color="#667085" />
                    <SolidColorBrush x:Key="ScrollBarThumbForeground" Color="#D0D5DD" />
                    <SolidColorBrush x:Key="ScrollBarThumbPointeroverForeground" Color="#98A2B3" />
                    <SolidColorBrush x:Key="ScrollBarBackground" Color="Transparent" />
                </ResourceDictionary>

                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="ScrollBarButtonDefaultForeground" Color="#7D8999" />
                    <SolidColorBrush x:Key="ScrollBarButtonPointeroverForeground" Color="#AAB4C3" />
                    <SolidColorBrush x:Key="ScrollBarThumbForeground" Color="#334155" />
                    <SolidColorBrush x:Key="ScrollBarThumbPointeroverForeground" Color="#667085" />
                    <SolidColorBrush x:Key="ScrollBarBackground" Color="Transparent" />
                </ResourceDictionary>

                <ResourceDictionary x:Key="{x:Static semi:SemiTheme.Aquatic}">
                    <SolidColorBrush x:Key="ScrollBarButtonDefaultForeground" Color="#7A99A1" />
                    <SolidColorBrush x:Key="ScrollBarButtonPointeroverForeground" Color="#5C7880" />
                    <SolidColorBrush x:Key="ScrollBarThumbForeground" Color="#CDE9EF" />
                    <SolidColorBrush x:Key="ScrollBarThumbPointeroverForeground" Color="#7A99A1" />
                    <SolidColorBrush x:Key="ScrollBarBackground" Color="Transparent" />
                </ResourceDictionary>

                <ResourceDictionary x:Key="{x:Static semi:SemiTheme.Desert}">
                    <SolidColorBrush x:Key="ScrollBarButtonDefaultForeground" Color="#9A856D" />
                    <SolidColorBrush x:Key="ScrollBarButtonPointeroverForeground" Color="#7A6752" />
                    <SolidColorBrush x:Key="ScrollBarThumbForeground" Color="#E8D9C2" />
                    <SolidColorBrush x:Key="ScrollBarThumbPointeroverForeground" Color="#9A856D" />
                    <SolidColorBrush x:Key="ScrollBarBackground" Color="Transparent" />
                </ResourceDictionary>

                <ResourceDictionary x:Key="{x:Static semi:SemiTheme.Dusk}">
                    <SolidColorBrush x:Key="ScrollBarButtonDefaultForeground" Color="#8A7A98" />
                    <SolidColorBrush x:Key="ScrollBarButtonPointeroverForeground" Color="#72637F" />
                    <SolidColorBrush x:Key="ScrollBarThumbForeground" Color="#DDD7EA" />
                    <SolidColorBrush x:Key="ScrollBarThumbPointeroverForeground" Color="#8A7A98" />
                    <SolidColorBrush x:Key="ScrollBarBackground" Color="Transparent" />
                </ResourceDictionary>

                <ResourceDictionary x:Key="{x:Static semi:SemiTheme.NightSky}">
                    <SolidColorBrush x:Key="ScrollBarButtonDefaultForeground" Color="#7F8CA3" />
                    <SolidColorBrush x:Key="ScrollBarButtonPointeroverForeground" Color="#AAB6C8" />
                    <SolidColorBrush x:Key="ScrollBarThumbForeground" Color="#3A4A66" />
                    <SolidColorBrush x:Key="ScrollBarThumbPointeroverForeground" Color="#AAB6C8" />
                    <SolidColorBrush x:Key="ScrollBarBackground" Color="Transparent" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Styles.Resources>
</Styles>
