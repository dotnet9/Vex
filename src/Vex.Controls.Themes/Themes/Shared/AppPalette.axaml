            <SolidColorBrush x:Key="MenuItemSeparatorBackground" Color="#2D3A52" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <Thickness x:Key="TopLevelMenuItemPadding">16 0</Thickness>
    <x:Double x:Key="MenuFlyoutMaxHeight">Infinity</x:Double>
