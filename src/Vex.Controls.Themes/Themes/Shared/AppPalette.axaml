            <SolidColorBrush x:Key="MenuItemPointeroverBackground" Color="#1E2A3F" />
            <SolidColorBrush x:Key="MenuItemPressedBackground" Color="#1E335A" />
            <SolidColorBrush x:Key="MenuItemInputGestureTextForeground" Color="#AAB6C8" />
            <SolidColorBrush x:Key="MenuItemExpandIconForeground" Color="#AAB6C8" />
            <SolidColorBrush x:Key="MenuItemExpandIconOpenForeground" Color="#FFFFFF" />
            <SolidColorBrush x:Key="MenuItemDisabledForeground" Color="#7F8CA3" />
